 #include <Mesh.h>
 #include "MyMesh.h"
 
+#ifdef PIN_BUZZER
+// Imperial March (Star Wars) — note arrays from Gemini
+static const int IMPERIAL_NOTES[] = {
+  440, 440, 440, 349, 523, 440, 349, 523, 440,  // A4 A4 A4 F4 C5 A4 F4 C5 A4
+  659, 659, 659, 698, 523, 415, 349, 523, 440   // E5 E5 E5 F5 C5 GS4 F4 C5 A4
+};
+static const int IMPERIAL_DURS[] = {
+  4, 4, 4, 5, 16, 4, 5, 16, 2,
+  4, 4, 4, 5, 16, 4, 5, 16, 2
+};
+static const int IMPERIAL_LEN = sizeof(IMPERIAL_NOTES) / sizeof(IMPERIAL_NOTES[0]);
+static int _melodyIdx = -1;
+static unsigned long _melodyNext = 0;
+static bool _melodyToneOn = false;
+
+void startMelody() { _melodyIdx = 0; _melodyNext = 0; _melodyToneOn = false; }
+
+void tickMelody() {
+  if (_melodyIdx < 0 || _melodyIdx >= IMPERIAL_LEN) return;
+  unsigned long now = millis();
+  if (!_melodyToneOn) {
+    int ms = 1200 / IMPERIAL_DURS[_melodyIdx];
+    tone(PIN_BUZZER, IMPERIAL_NOTES[_melodyIdx], ms);
+    _melodyToneOn = true;
+    _melodyNext = now + ms * 1.3;
+  }
+  if (now >= _melodyNext) {
+    noTone(PIN_BUZZER);
+    _melodyIdx++;
+    _melodyToneOn = false;
+    if (_melodyIdx >= IMPERIAL_LEN) _melodyIdx = -1;
+  }
+}
+#endif
+
